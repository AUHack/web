mixin set_buttons()
  .row: .col-sm-12
    h2 Events
    a#back-to-top.btn.btn-lg.back-to-top.smoothscroll(href="#cards-section" role="button" title="Click to return to top" data-toggle="tooltip" data-placement="left")
      span.fa.fa-chevron-up
    .text-center
      each item in events
        a.smoothscroll.btn.btn-secondary(href="#" + item.id) #{item.name}
    hr
  
mixin set_cards()
  .row 
    .col-sm-6
      each item, index in events
        if (index % 2 == 0)
          +set_cards_helper(item)
    .col-sm-6
      each item, index in events
        if (index % 2 == 1)
          +set_cards_helper(item)
  
mixin set_cards_helper(item)
  .card(id=item.id)
    img.card-img-top(src=("img/events/" + item.id + ".jpg") alt=item.name)
    .card-body
      h5= item.name
      i.text-muted= item.time
      br
      i.text-muted= item.location
      hr
      h6 Sign-up specifics
      p!= item.signup
      h6 Description
      p!= item.description

section.cards-section#cards-section(class="triangle"): .container
  +set_buttons()
  +set_cards()